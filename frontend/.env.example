# MCP HTTP endpoint (streamable HTTP path). Used as default in the UI and to set the dev proxy target origin.
VITE_MCP_URL=http://127.0.0.1:8000/mcp

# Optional: MCP client request timeouts (milliseconds).
# The SDK default is 60000 (60s), which is too short for orchestrate_autofix.
# VITE_MCP_ORCHESTRATE_TIMEOUT_MS=900000
# VITE_MCP_RESOLVE_TIMEOUT_MS=120000
